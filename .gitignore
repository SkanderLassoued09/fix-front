.env
.env.*
!.env.example

# =============================================================================
# IDE / Editor — JetBrains
# =============================================================================
.idea/
*.iml

# =============================================================================
# IDE / Editor — VSCode
# (don't share machine-specific settings; whitelist .vscode/extensions.json
#  here if the team agrees on a shared recommendation list)
# =============================================================================
.vscode/
.history/

# =============================================================================
# IDE / Editor — Eclipse / Sublime / Cloud9
# =============================================================================
.project
.classpath
.settings/
.c9/
*.launch
*.sublime-workspace

# =============================================================================
